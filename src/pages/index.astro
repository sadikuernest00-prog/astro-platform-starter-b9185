<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>AmicBridge — Private Capital Network</title>

<meta name="description"
content="AmicBridge is a private lending and capital network based in Norway. Trust before money. Structured agreements and defined returns." />

<style>
:root {
  --bg:#f3f4f6;
  --white:#ffffff;
  --border:#d1d5db;
  --text:#111827;
  --muted:#6b7280;
  --primary:#1d4ed8;
  --primary-dark:#1e3a8a;
  --soft:#e6f0ea;
}

*{box-sizing:border-box}

body{
  margin:0;
  font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
  background:var(--bg);
  color:var(--text);
}

/* Header */
header{
  background:var(--white);
  border-bottom:1px solid var(--border);
  padding:18px 28px;
  display:flex;
  justify-content:space-between;
  align-items:center;
}

.logo{
  font-weight:800;
  font-size:24px;
  letter-spacing:.5px;
}

.tagline{
  font-size:13px;
  color:var(--muted);
}

nav a{
  margin-left:18px;
  text-decoration:none;
  font-weight:600;
  font-size:14px;
  color:var(--text);
}

nav a:hover{ text-decoration:underline; }

/* Layout */
.container{
  max-width:1000px;
  margin:auto;
  padding:40px 24px 60px;
}

h1{
  font-size:42px;
  margin:10px 0;
}

p.lead{
  color:var(--muted);
  font-size:17px;
  max-width:700px;
}

.section{
  margin-top:40px;
}

.card{
  background:var(--white);
  border:1px solid var(--border);
  border-radius:14px;
  padding:22px;
}

/* Offer */
.offer{
  background:var(--soft);
  border:1px solid var(--border);
  border-radius:16px;
  padding:24px;
  margin-top:14px;
}

.offer-header{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:14px;
  gap:12px;
}

.offer-header h2{
  margin:0;
  font-size:20px;
  line-height:1.2;
}

.badge{
  border:1px solid var(--border);
  background:#fff;
  padding:6px 12px;
  border-radius:999px;
  font-size:12px;
  font-weight:700;
  white-space:nowrap;
}

.grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:12px;
  margin-top:16px;
}

.box{
  background:#fff;
  border:1px solid var(--border);
  border-radius:12px;
  padding:14px;
}

.label{
  font-size:12px;
  color:var(--muted);
  font-weight:700;
}

.value{
  font-size:20px;
  font-weight:800;
  margin-top:4px;
}

.small{
  font-size:12px;
  color:var(--muted);
  margin-top:12px;
}

.button{
  display:inline-block;
  margin-top:16px;
  padding:12px 18px;
  background:var(--primary);
  color:#fff;
  border-radius:10px;
  text-decoration:none;
  font-weight:700;
}

.button:hover{
  background:var(--primary-dark);
}

footer{
  margin-top:60px;
  font-size:13px;
  color:var(--muted);
}

/* Mobile */
@media(max-width:800px){
  .grid{grid-template-columns:1fr;}
  h1{font-size:32px;}
  header{flex-direction:column;align-items:flex-start}
  nav{margin-top:10px}
}
</style>
</head>

<body>

<header>
  <div>
    <div class="logo">AMICBRIDGE</div>
    <div class="tagline">Based in Norway · Private lending & investing network</div>
  </div>
  <nav>
    <a href="#offer">Current Offers</a>
    <a href="#contact">Contact</a>
  </nav>
</header>

<div class="container">

  <h1>Trust before money.</h1>
  <p class="lead">
    AmicBridge connects private capital with businesses and individuals seeking growth.
    We structure transparent agreements with defined repayment terms.
    Returns depend on the active offer and the written agreement.
  </p>

  <div class="section" id="offer">
    <h2>Current Offers</h2>

    <!-- Offer 1 -->
    <div class="offer">
      <div class="offer-header">
        <h2>Lend 45,000 → Receive 52,000 in 4 weeks</h2>
        <span class="badge">Profit 7,000</span>
      </div>

      <p class="lead" style="margin:0;">
        This is the current active offer available through AmicBridge.
        Repayment is scheduled 4 weeks after funding, as defined in the written agreement.
      </p>

      <div class="grid">
        <div class="box">
          <div class="label">Lend</div>
          <div class="value">45,000</div>
        </div>
        <div class="box">
          <div class="label">Return (repayment)</div>
          <div class="value">52,000</div>
        </div>
        <div class="box">
          <div class="label">Profit</div>
          <div class="value">7,000</div>
        </div>
      </div>

      <p class="small">
        Capital involves risk. Repayment, timing and performance are defined in the written agreement.
      </p>
    </div>

    <!-- Offer 2 (new) -->
    <div class="offer">
      <div class="offer-header">
        <h2>Lend 10,000 → Receive 13,000 in 4 weeks</h2>
        <span class="badge">Profit 3,000</span>
      </div>

      <p class="lead" style="margin:0;">
        This is an additional active offer available through AmicBridge.
        Repayment is scheduled 4 weeks after funding, as defined in the written agreement.
      </p>

      <div class="grid">
        <div class="box">
          <div class="label">Lend</div>
          <div class="value">10,000</div>
        </div>
        <div class="box">
          <div class="label">Return (repayment)</div>
          <div class="value">13,000</div>
        </div>
        <div class="box">
          <div class="label">Profit</div>
          <div class="value">3,000</div>
        </div>
      </div>

      <p class="small">
        Capital involves risk. Repayment, timing and performance are defined in the written agreement.
      </p>
    </div>

  </div>

  <div class="section" id="contact">
    <div class="card">
      <h2>Contact CEO Robert</h2>
      <p class="lead">
        For more information about these offers or future capital opportunities,
        please contact us directly.
      </p>

      <a class="button" href="mailto:amicbridgecontact@gmail.com?subject=AmicBridge%20Inquiry">
        Email: amicbridgecontact@gmail.com
      </a>
    </div>
  </div>

  <footer>
    © <span id="year"></span> AmicBridge. All rights reserved.
  </footer>

</div>

<script>
document.getElementById("year").textContent = new Date().getFullYear();
</script>

</body>
</html>
