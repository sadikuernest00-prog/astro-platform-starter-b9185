<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>AmicBridge — Private Capital Network</title>

<meta name="description"
content="AmicBridge is a private lending and investing network based in Norway. Trust before money. Structured agreements and defined 4-week repayment terms." />

<style>
:root{
  --bg:#f3f4f6;
  --white:#ffffff;
  --border:#d1d5db;
  --text:#111827;
  --muted:#6b7280;
  --primary:#1d4ed8;
  --primary-dark:#1e3a8a;
  --soft:#e6f0ea;
}

*{box-sizing:border-box}

body{
  margin:0;
  font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
  background:var(--bg);
  color:var(--text);
}

/* Header */
header{
  background:var(--white);
  border-bottom:1px solid var(--border);
  padding:18px 28px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  flex-wrap:wrap;
}

.logo{font-weight:800;font-size:24px;letter-spacing:.5px}
.tagline{font-size:13px;color:var(--muted);margin-top:4px}

nav{display:flex;gap:18px;flex-wrap:wrap}
nav a{
  text-decoration:none;
  font-weight:600;
  font-size:14px;
  color:var(--text);
}
nav a:hover{text-decoration:underline}

/* Layout */
.container{max-width:1000px;margin:auto;padding:40px 24px 60px}
.pill-top{
  display:inline-block;
  padding:6px 12px;
  border-radius:999px;
  border:1px solid var(--border);
  background:#fff;
  font-size:12px;
  font-weight:800;
  color:var(--primary-dark);
}
h1{font-size:42px;margin:12px 0}
.lead{color:var(--muted);font-size:17px;max-width:750px;line-height:1.5}
.section{margin-top:40px}
.section-title{font-size:22px;margin-bottom:14px}

/* Offer Cards */
.offers{display:grid;gap:18px}
.offer{
  background:var(--soft);
  border:1px solid var(--border);
  border-radius:16px;
  padding:24px;
}
.offer-header{
  display:flex;
  justify-content:space-between;
  align-items:flex-start;
  gap:12px;
  margin-bottom:10px;
}
.offer-header h3{
  margin:0;
  font-size:20px;
  line-height:1.3;
}
.badge{
  border:1px solid var(--border);
  background:#fff;
  padding:6px 12px;
  border-radius:999px;
  font-size:12px;
  font-weight:900;
}
.offer-text{
  margin:0;
  color:var(--muted);
  font-size:15px;
}
.grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:12px;
  margin-top:14px;
}
.box{
  background:#fff;
  border:1px solid var(--border);
  border-radius:12px;
  padding:14px;
}
.label{font-size:12px;color:var(--muted);font-weight:800}
.value{font-size:20px;font-weight:900;margin-top:4px}
.small{font-size:12px;color:var(--muted);margin-top:12px}

/* Contact */
.card{
  background:var(--white);
  border:1px solid var(--border);
  border-radius:14px;
  padding:22px;
}
.button{
  display:inline-block;
  margin-top:14px;
  padding:12px 18px;
  background:var(--primary);
  color:#fff;
  border-radius:10px;
  text-decoration:none;
  font-weight:800;
}
.button:hover{background:var(--primary-dark)}

footer{margin-top:60px;font-size:13px;color:var(--muted)}

/* Mobile */
@media(max-width:800px){
  h1{font-size:32px}
  .grid{grid-template-columns:1fr}
}
</style>
</head>

<body>

<header>
  <div>
    <div class="logo">AMICBRIDGE</div>
    <div class="tagline">Based in Norway · Private lending & investing network</div>
  </div>
  <nav>
    <a href="#offers">Offers</a>
    <a href="#contact">Contact</a>
  </nav>
</header>

<main class="container">

  <span class="pill-top">✓ TRUST BEFORE MONEY</span>

  <h1>Structured 4-week capital opportunities.</h1>
  <p class="lead">
    AmicBridge connects private capital with verified short-term funding needs.
    All offers operate on a defined 4-week repayment term.
    Repayment amounts, timing, and obligations are defined in written agreements.
  </p>

  <section class="section" id="offers">
    <h2 class="section-title">Current Offers (4 weeks)</h2>

    <div class="offers">

      <!-- Tier A -->
      <div class="offer">
        <div class="offer-header">
          <h3>Tier A (Secured) — Invest 10,000 → Receive 11,000 in 4 weeks</h3>
          <span class="badge">Profit 1,000 · Lower risk</span>
        </div>
        <p class="offer-text">
          Secured structure with defined collateral. Repayment scheduled 4 weeks after funding.
        </p>
        <div class="grid">
          <div class="box"><div class="label">Investment</div><div class="value">10,000</div></div>
          <div class="box"><div class="label">Return</div><div class="value">11,000</div></div>
          <div class="box"><div class="label">Profit</div><div class="value">1,000</div></div>
        </div>
        <p class="small">Capital involves risk. Terms are defined in the written agreement.</p>
      </div>

      <!-- Tier B -->
      <div class="offer">
        <div class="offer-header">
          <h3>Tier B (Verified Source) — Invest 25,000 → Receive 28,000 in 4 weeks</h3>
          <span class="badge">Profit 3,000 · Medium risk</span>
        </div>
        <p class="offer-text">
          Verified repayment source (contract / invoice / closing). Repayment scheduled 4 weeks after funding.
        </p>
        <div class="grid">
          <div class="box"><div class="label">Investment</div><div class="value">25,000</div></div>
          <div class="box"><div class="label">Return</div><div class="value">28,000</div></div>
          <div class="box"><div class="label">Profit</div><div class="value">3,000</div></div>
        </div>
        <p class="small">Capital involves risk. Terms are defined in the written agreement.</p>
      </div>

      <!-- Tier C -->
      <div class="offer">
        <div class="offer-header">
          <h3>Tier C (Special Situation) — Invest 45,000 → Receive 52,000 in 4 weeks</h3>
          <span class="badge">Profit 7,000 · Higher risk</span>
        </div>
        <p class="offer-text">
          Higher-yield opportunity. Repayment scheduled 4 weeks after funding under written agreement.
        </p>
        <div class="grid">
          <div class="box"><div class="label">Investment</div><div class="value">45,000</div></div>
          <div class="box"><div class="label">Return</div><div class="value">52,000</div></div>
          <div class="box"><div class="label">Profit</div><div class="value">7,000</div></div>
        </div>
        <p class="small">Capital involves risk. Terms are defined in the written agreement.</p>
      </div>

    </div>
  </section>

  <section class="section" id="contact">
    <div class="card">
      <h2>Contact CEO Ernest</h2>
      <p class="lead">
        For participation in current offers or to discuss capital opportunities,
        please contact AmicBridge directly.
      </p>
      <a class="button" href="mailto:amicbridgecontact@gmail.com?subject=AmicBridge Inquiry">
        Email: amicbridgecontact@gmail.com
      </a>
    </div>
  </section>

  <footer>
    © <span id="year"></span> AmicBridge. All rights reserved.
  </footer>

</main>

<script>
document.getElementById("year").textContent = new Date().getFullYear();
</script>

</body>
</html>
